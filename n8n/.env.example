# Environment variables required by the n8n workflows.
#
# Set these on your n8n instance (Docker -e, settings UI, or your host's
# env-var system). They are read inside Code nodes via $env.
#
# DO NOT commit a populated copy of this file. Only this template lives in git.

# Platform login (read by 02-scraper.json and the 01-* archive workflows).
BENEFITS_EMAIL=you@example.com
BENEFITS_PASSWORD=replace-me

# n8n API key — used by Code nodes to call /api/v1/data-tables/<id>/rows.
# Generate one at: n8n -> Settings -> n8n API -> Create API Key.
N8N_API_KEY=replace-me

# Optional documentation-only values (not read by any workflow today; kept here
# so a fresh setup has a single place to record per-instance config):
BENEFITS_PLATFORM_TENANT=ibmcic
BENEFITS_PLATFORM_HOST=https://ibmcic.benefitsatwork.be
N8N_BASE_URL=https://n8n.qinclaes.dev
N8N_PUBLISH_WEBHOOK_PATH=benefits-partners
LLM_MODEL=claude-haiku-4-5
LLM_CREDENTIAL_NAME=IBM ICA OpenAI
SCRAPER_CRON=0 4 * * 0
